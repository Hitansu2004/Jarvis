# =============================================================================
# PROJECT J.A.R.V.I.S. — Master Environment Configuration v5.0
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- OPERATION MODE -----------------------------------------------------------
# "offline" = all LLM calls go to Ollama (local, private, default)
# "online"  = all LLM calls go to Vertex AI (Gemini 2.5 family)
OPERATION_MODE=offline

# --- SERVER -------------------------------------------------------------------
SERVER_PORT=8000
LOG_LEVEL=INFO

# --- ROUTING ------------------------------------------------------------------
# Complexity score at or above this threshold routes to specialist models
COMPLEXITY_THRESHOLD=7
# Set to "true" to force Gemma 4 E4B for everything (low-RAM/prototype mode)
PROTOTYPE_MODE=false

# --- OLLAMA (OFFLINE MODE) ----------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0

# --- OFFLINE MODEL ASSIGNMENTS ------------------------------------------------
MODEL_RECEPTIONIST=gemma4:e4b
MODEL_ORCHESTRATOR=qwen3.5:27b-q4_K_M
MODEL_SPECIALIST_CODE=gemma4:26b
MODEL_VISION_PASSIVE=gemma4:e4b
MODEL_VISION_DEEP=gemma4:26b
MODEL_AUDITOR=gemma4:e4b
MODEL_MEMORY_DISTILLER=gemma4:e4b
MODEL_VOICE_TRIAGE=gemma4:e4b

# --- TTS CONFIGURATION --------------------------------------------------------
TTS_ENGINE_PRIMARY=f5tts
TTS_VOICE_REF_FILE=~/voice_engine/jarvis_ref.wav
TTS_VOICE_REF_TEXT=All systems are functioning within normal parameters, sir.
TTS_ENGINE_MULTILINGUAL=chatterbox
TTS_ENGINE_FAST=kokoro

# --- STT CONFIGURATION --------------------------------------------------------
STT_MODEL=whisper-small
# Options: mps (Mac M4), cuda (NVIDIA), cpu (fallback)
STT_DEVICE=mps

# --- WAKE WORD ----------------------------------------------------------------
WAKE_WORD=Hey Jarvis

# --- SCREEN VISION ------------------------------------------------------------
SCREEN_VISION_ENABLED=true
SUGGESTION_COOLDOWN_SECONDS=120

# --- OVERLAY ------------------------------------------------------------------
JARVIS_OVERLAY_COLOR=#FF0000

# --- VERTEX AI (ONLINE MODE) --------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=~/jarvis_vertex_key.json
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# --- ONLINE MODEL ASSIGNMENTS -------------------------------------------------
# Complexity 8+ → Pro, 5-7 → Flash, 1-4 → Flash-Lite
MODEL_ONLINE_COMPLEX=gemini-2.5-pro
MODEL_ONLINE_MEDIUM=gemini-2.5-flash
MODEL_ONLINE_LIGHT=gemini-2.5-flash-lite
COMPLEXITY_VERTEX_PRO=8
COMPLEXITY_VERTEX_FLASH=5

# --- FALLBACK API KEYS (emergency only, not primary stack) --------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
PREFERRED_FALLBACK_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-your-key-here

# --- TELEGRAM BOT (Phase 10 interface) ----------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- MCP API KEYS (Phase 8 — activated when MCP servers are installed) --------
# GitHub MCP — for code_specialist and orchestrator agents
GITHUB_TOKEN=ghp_your-github-token-here

# Composio MCP — for communication agent (Gmail, Slack, Jira, Notion, etc.)
COMPOSIO_API_KEY=your-composio-api-key-here

# Brave Search MCP — for research agent (offline mode web search)
BRAVE_API_KEY=your-brave-search-api-key-here

# --- MODELS DIRECTORY ---------------------------------------------------------
# Optional: set this to store Ollama models inside the project models/ directory
# instead of the default ~/.ollama/models/
# OLLAMA_MODELS=/Users/hparichha/Documents/Jarvis/jarvis/models

# --- MEMORY SYSTEM (Phase 4) --------------------------------------------------
# ChromaDB — vector similarity store
CHROMA_PERSIST_DIR=./memory_vault/chroma_db

# Graphiti — temporal knowledge graph (uses Kuzu as embedded backend)
GRAPHITI_DB_DIR=./memory_vault/kuzu_db
GRAPHITI_EMBEDDING_MODEL=nomic-embed-text

# Wiki — compiled Markdown knowledge base
WIKI_DIR=./memory_vault/wiki

# Distillation job schedule (cron expression — default 2:00 AM daily)
DISTILLER_SCHEDULE=0 2 * * *
# Max log size per day before distillation is forced (MB)
DISTILLER_FORCE_THRESHOLD_MB=50

# Passive screen learning — controls what gets observed
PASSIVE_LEARNING_ENABLED=true
PASSIVE_LEARN_CODE_STYLE=true
PASSIVE_LEARN_APP_PATTERNS=true
PASSIVE_LEARN_BROWSING=true
PASSIVE_LEARN_SHOPPING=true
PASSIVE_LEARNING_PAUSE_MINUTES=0  # 0 = not paused

# Memory retrieval — how many facts to inject per prompt
MEMORY_TOP_K=5
MEMORY_MIN_RELEVANCE=0.65

# Memory correction sensitivity
CORRECTION_PHRASE_THRESHOLD=0.85  # cosine similarity to trigger correction parsing
